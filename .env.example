# ── Project Configuration ─────────────────────────────────────────
PROJECT_NAME=three-tier-application
NODE_ENV=development

# ── MongoDB Configuration ─────────────────────────────────────────
# Database name used during initialization and by services
MONGO_INITDB_DATABASE=three-tier-application

# Connection URI for the backend and worker
# When running with Docker Compose, use 'mongo' as the hostname
MONGO_URI=mongodb://mongo:27017/three-tier-application

# ── Redis Configuration ───────────────────────────────────────────
# When running with Docker Compose, use 'redis' as the hostname
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Backend API Configuration ─────────────────────────────────────
# The port the backend server listens on
PORT=5000

# Security
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long
JWT_EXPIRES_IN=7d


# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# ── Worker Configuration ──────────────────────────────────────────
# Logging level for the Python worker (ERROR, WARNING, INFO, DEBUG)
WORKER_LOG_LEVEL=INFO

# ── Frontend Configuration ────────────────────────────────────────
# URL of the Backend API (e.g. http://1.2.3.4).
NEXT_PUBLIC_API_URL=http://backend:5000
