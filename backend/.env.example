# Node environment
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://mongo:27017/ai-task-platform

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
